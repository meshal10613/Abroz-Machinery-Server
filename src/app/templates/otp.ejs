<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Verify Your Account</title>

  <style>
    body {
      margin: 0;
      padding: 40px 16px;
      background: #f4f7fb;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
      color: #1e293b;
    }

    .container {
      max-width: 560px;
      margin: 0 auto;
    }

    .card {
      background: #ffffff;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 10px 40px rgba(15, 23, 42, 0.08);
    }

    .header {
      background: linear-gradient(
        135deg,
        #2563eb 0%,
        #4f46e5 50%,
        #7c3aed 100%
      );
      padding: 50px 32px;
      text-align: center;
    }

    .logo {
      width: 60px;
      height: 60px;
      margin: 0 auto 20px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.15);
      line-height: 60px;
      font-size: 28px;
      color: white;
      font-weight: bold;
    }

    .header h1 {
      margin: 0;
      color: white;
      font-size: 28px;
      font-weight: 700;
    }

    .header p {
      margin-top: 10px;
      color: rgba(255, 255, 255, 0.85);
      font-size: 15px;
    }

    .content {
      padding: 40px 32px;
    }

    .greeting {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .message {
      font-size: 15px;
      line-height: 1.7;
      color: #64748b;
      margin-bottom: 32px;
    }

    .otp-wrapper {
      text-align: center;
      margin: 30px 0;
    }

    .otp-label {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #94a3b8;
      margin-bottom: 18px;
    }

    .otp-box {
      display: inline-block;
      width: 54px;
      height: 60px;
      line-height: 60px;
      margin: 0 4px;
      border-radius: 14px;
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      font-size: 24px;
      font-weight: 700;
      color: #1e293b;
      text-align: center;
    }

    .expiry {
      margin-top: 24px;
      padding: 14px 18px;
      border-radius: 12px;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      text-align: center;
      font-size: 14px;
      color: #1d4ed8;
      font-weight: 600;
    }

    .security {
      margin-top: 28px;
      padding: 18px;
      background: #f8fafc;
      border-radius: 14px;
      border: 1px solid #e2e8f0;
    }

    .security-title {
      font-size: 14px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #0f172a;
    }

    .security-text {
      font-size: 13px;
      line-height: 1.7;
      color: #64748b;
    }

    .footer {
      text-align: center;
      padding: 24px;
      border-top: 1px solid #f1f5f9;
      color: #94a3b8;
      font-size: 12px;
      line-height: 1.7;
    }

    @media only screen and (max-width: 600px) {
      .content {
        padding: 32px 20px;
      }

      .otp-box {
        width: 42px;
        height: 50px;
        line-height: 50px;
        font-size: 20px;
        margin: 2px;
      }

      .header {
        padding: 40px 20px;
      }

      .header h1 {
        font-size: 24px;
      }
    }
  </style>
</head>

<body>
  <%
    const digits = String(otp || "").split("");
  %>

  <div class="container">
    <div class="card">

      <div class="header">
        <div class="logo">🔐</div>
        <h1>Verify your email</h1>
        <p>Secure access with your one-time verification code</p>
      </div>

      <div class="content">

        <div class="greeting">
          Hello <strong><%= name %></strong>,
        </div>

        <div class="message">
          We received a request to verify your account. Use the verification code below to continue. This code is valid for a limited time.
        </div>

        <div class="otp-wrapper">

          <div class="otp-label">
            Your Verification Code
          </div>

          <% digits.forEach(d => { %>
            <span class="otp-box"><%= d %></span>
          <% }) %>

        </div>

        <div class="expiry">
          ⏱ Expires in 5 minutes
        </div>

        <div class="security">
          <div class="security-title">
            Security Notice
          </div>

          <div class="security-text">
            Never share this code with anyone. Our team will never ask for your OTP via email, phone, or chat. If you did not request this code, you can safely ignore this email.
          </div>
        </div>

      </div>

      <div class="footer">
        © <%= new Date().getFullYear() %> Abroz Machinery<br />
        This is an automated message. Please do not reply to this email.
      </div>

    </div>
  </div>
</body>
</html>